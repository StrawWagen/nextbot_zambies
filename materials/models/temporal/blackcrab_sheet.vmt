SDK_VertexLitGeneric
{
	"$baseTexture" "models/Temporal/Blackcrab_sheet"
	"$bumpmap" "models/Temporal/blackcrab_sheet_normal"
	"$phong"	"1"
	"$phongexponenttexture" "models/Temporal/blackcrab_sheet_phong"
 	"$phongexponent"	"28"
	"$phongboost"	"5"
	"$phongfresnelranges"   "[1 .5 2]"
	"$phongdisablehalflambert" "1"
	"$phongwarptexture"  "models/Temporal/blackcrab_iridescence"
	//"$translucent" "1"

	"$selfillum" "1"
	"$selfIllumFresnel" "1"
	"$selfIllumFresnelMinMaxExp" "[0.0 0.5 0.25]" // 0.0 1.0 1.0 is the default
	"$selfillumtint"	"[0.23 0.26 0.78]"

	//rimlight parameters
	"$rimlight" "1"
	"$rimlightexponent" "10"
	"$rimlightboost" "10"

	"Proxies"
	{
		"TextureScroll"
		{
			"texturescrollvar" "$bumptransform"
			"texturescrollrate" .25
			"texturescrollangle" 45.00
		}
	}
}
